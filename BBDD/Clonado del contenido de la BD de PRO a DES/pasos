🥇 PASO 4 — Desplegar MariaDB en desarrollo
kubectl -n desarrollo create secret generic mariadb-secret \
  --from-literal=MARIADB_ROOT_PASSWORD=RootPass123 \
  --from-literal=MARIADB_DATABASE=yourls

kubectl apply -f mariadb-pvc-des.yaml
kubectl apply -f mariadb-deployment-des.yaml
kubectl apply -f mariadb-service-des.yaml

kubectl -n desarrollo get pods
kubectl -n desarrollo get pvc
kubectl -n desarrollo get svc

kubectl -n desarrollo get pods
kubectl -n desarrollo exec -it mariadb-78b5f45974-54pq4 -- bash
mariadb -u root -p -> RootPass123

SHOW DATABASES;
USE yourls;
SHOW TABLES;

🥇 PASO 6 — Exportar SOLO la tabla desde PRODUCCIÓN
kubectl -n produccion get pods
kubectl -n produccion exec mariadb-78b5f45974-qz58b -- \
mariadb-dump -u root -pRootPass123 yourls yourls_url > yourls_url.sql

*Se descarga el dump en la ruta que estemos (pwd)
ls -lh yourls_url.sql

🥇 PASO 7 — Importación en DES
7.1 Copiar el dump al pod de desarrollo
kubectl -n desarrollo get pods
kubectl -n desarrollo cp yourls_url.sql mariadb-78b5f45974-54pq4:/tmp/yourls_url.sql
kubectl -n desarrollo exec -it mariadb-78b5f45974-54pq4 -- sh -c "ls -lh /tmp"

7.2 Importar contenido en DES
kubectl -n desarrollo exec -it mariadb-78b5f45974-54pq4 -- bash
mariadb -u root -p -> RootPass123
USE yourls;
SOURCE /tmp/yourls_url.sql;

7.3 Validación post-import
SELECT COUNT(*) FROM yourls_url;